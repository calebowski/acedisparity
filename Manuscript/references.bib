	shorttitle = {Mammals across the {K}/{Pg} boundary in northeastern {Montana}, {U}.{S}.{A}.},

	doi = {10.1666/12041},
	abstract = {The Cretaceous/Tertiary (K/Pg) mass extinction has long been viewed as a pivotal event in mammalian evolutionary history, in which the extinction of non-avian dinosaurs allowed mammals to rapidly expand from small-bodied, generalized insectivores to a wide array of body sizes and ecological specializations. Many studies have used global- or continental-scale taxonomic databases to analyze this event on coarse temporal scales, but few studies have documented morphological diversity of mammalian paleocommunities on fine spatiotemporal scales in order to examine ecomorphological selectivity and ecospace filling across this critical transition. Focusing on well-sampled and temporally well-constrained mammalian faunas across the K/Pg boundary in northeastern Montana, I quantified dental-shape disparity and morphospace occupancy via landmark- and semilandmark-based geometric morphometrics and mean body size, body-size disparity, and body-size structure via body-mass estimates.},
	language = {en},
	number = {3},

	journal = {Paleobiology},
	author = {Wilson, Gregory P.},
	year = {2013},
	pages = {429--469},
	file = {PDF:/home/caleb/Zotero/storage/DFISHNAG/Wilson - 2013 - Mammals across the KPg boundary in northeastern Montana, U.S.A. dental morphology and body-size pa.pdf:application/pdf},
}

